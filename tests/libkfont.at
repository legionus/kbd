AT_BANNER([libkfont unit tests])

AT_SETUP([test 01 (get_unicodemap retries after ENOMEM)])
AT_KEYWORDS([libkfont unittest])
UNITTEST_MEMCHECK([$abs_builddir/libkfont/libkfont-test01])
AT_CLEANUP

AT_SETUP([test 02 (get_font reads regular font)])
AT_KEYWORDS([libkfont unittest])
UNITTEST_MEMCHECK([$abs_builddir/libkfont/libkfont-test02])
AT_CLEANUP

AT_SETUP([test 03 (get_font retries with GET_TALL)])
AT_KEYWORDS([libkfont unittest])
UNITTEST_MEMCHECK([$abs_builddir/libkfont/libkfont-test03])
AT_CLEANUP
