msgid "display keytable in hexadecimal notation."
msgstr "اعرض جدول المفاتيح بالتمثيل الست عشري."

#: src/dumpkeys.c:91
msgid "don't use short-hand notations, one row per keycode."
msgstr "لا تستخدم الاختصارات، صف واحد لكل رمز مفتاح."

#: src/dumpkeys.c:92
msgid "one line per (modifier,keycode) pair."
msgstr "سطر واحد لكل زوج (مغير، رمز مفتاح)."

#: src/dumpkeys.c:94
msgid "display only the function key strings."
msgstr "اعرض سلاسل مفاتيح الوظائف فقط."

